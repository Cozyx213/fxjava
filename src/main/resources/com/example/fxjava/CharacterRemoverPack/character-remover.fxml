<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.fxjava.CharacterRemoverPack.CharacterRemoverController">
   <children>
      <Button fx:id="removeButton" layoutX="274.0" layoutY="280.0" mnemonicParsing="false" onAction="#remove" text="Remove" />
      <CheckBox fx:id="vowelCheckbox" layoutX="165.0" layoutY="238.0" mnemonicParsing="false" text="Vowels" />
      <CheckBox fx:id="consonantCheckbox" layoutX="269.0" layoutY="238.0" mnemonicParsing="false" text="Consonants" />
      <CheckBox fx:id="numberCheckbox" layoutX="363.0" layoutY="238.0" mnemonicParsing="false" text="Numbers" />
      <Button fx:id="restoreButton" layoutX="274.0" layoutY="330.0" mnemonicParsing="false" onAction="#restore" text="Restore" />
      <Label fx:id="textLabel" alignment="CENTER" layoutX="172.0" layoutY="113.0" prefHeight="17.0" prefWidth="257.0" text="ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789" textAlignment="CENTER" />
   </children>
</AnchorPane>
